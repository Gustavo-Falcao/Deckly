            {
                "id": "1fca2ec2-ca98-435d-b3bc-4fe8c35d9ddd",
                "name": "Eager",
                "context": "adjective",
                "synonym": "",
                "phonetic": "ÍÍ-gâr",
                "creationDate": "2026-06-03T22:04:50.873Z",
                "meanings": [
                    {
                        "id": "abbf22ae-465b-41df-9a32-0e216a876393",
                        "definition": "Very interested, excited, or enthusiastic about doing something.",
                        "contexts": [
                            {
                                "id": "1d93fe0a-f12e-4542-94c3-c17dc5dcea6e",
                                "context": "literal"
                            }
                        ],
                        "examples": [
                            {
                                "id": "a3d12143-3f3d-4163-94a3-2ce51b127a8a",
                                "text": "The students are eager to begin their research projects.",
                                "targetToBeHidden": "eager"
                            },
                            {
                                "id": "9a4c284c-d200-44d4-88f7-5c2061d55c9b",
                                "text": "She’s eager to see the new movie this weekend.",
                                "targetToBeHidden": "eager"
                            },
                            {
                                "id": "f7a26f4a-f1b2-4a36-b520-55c509ee2f26",
                                "text": "Most customers were eager to be interviewed; less than 10 refused to participate in each study.",
                                "targetToBeHidden": "eager"
                            }
                        ],
                        "nextReviewDate": "2026-06-20T03:00:00.000Z",
                        "interval": 4,
                        "repetitions": 2,
                        "easeFactor": 2.5
                    }
                ]
            },
            {
                "id": "0a63c928-7301-48e2-aceb-949f04fc16e7",
                "name": "Unwell",
                "context": "adjective",
                "synonym": "",
                "phonetic": "ân-UÉL",
                "creationDate": "2026-06-03T22:02:03.550Z",
                "meanings": [
                    {
                        "id": "f58ff557-6a5e-40fd-8eaa-f9149a463199",
                        "definition": "Not healthy, sick, or not feeling good.",
                        "contexts": [
                            {
                                "id": "5f722477-3ef3-47d8-b273-9de2316c75e0",
                                "context": "formal"
                            }
                        ],
                        "examples": [
                            {
                                "id": "6550009a-c1cb-40c8-8220-a45ddbcab117",
                                "text": "The patient is feeling unwell and requires rest.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "7c246622-fdd1-43f2-873b-377b52bbd28a",
                                "text": "I’m a bit unwell today, so I’ll stay home.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "e8486374-a341-4c65-b666-8d62f6a49f38",
                                "text": "Cases who had been overseas shortly before becoming unwell were not excluded.",
                                "targetToBeHidden": ""
                            }
                        ],
                        "nextReviewDate": "2026-06-03T22:02:03.550Z",
                        "interval": 0,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    }
                ]
            },
            {
                "id": "cefa5306-2622-43c8-a37a-2069d0092f46",
                "name": "Willing",
                "context": "adjective",
                "synonym": "",
                "phonetic": "UÍL-lin",
                "creationDate": "2026-06-03T21:53:18.934Z",
                "meanings": [
                    {
                        "id": "9ae2c4b0-6a7e-4f96-aff3-20a5d61577f5",
                        "definition": "Being ready, eager, or prepared to do something; often because you agree or don’t mind doing it.",
                        "contexts": [
                            {
                                "id": "6cb159a0-62ae-4bb8-a884-bfaa7ef4fca5",
                                "context": "literal"
                            }
                        ],
                        "examples": [
                            {
                                "id": "d5f85c60-6f14-4caf-a151-34bed43fb83b",
                                "text": "The committee is willing to consider your proposal.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "7bab24c7-83af-41f8-a038-44ad4f8325c5",
                                "text": "I’m willing to help you move this weekend.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "5a5dc2b7-88a9-4b8f-a1c8-e911125619a8",
                                "text": "If you’re willing to fly on Thursday you can get a cheaper ticket.",
                                "targetToBeHidden": ""
                            }
                        ],
                        "nextReviewDate": "2026-06-03T21:53:18.934Z",
                        "interval": 0,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    }
                ]
            },
            {
                "id": "d51a8459-d9da-4347-aa44-1a9f47e2e7de",
                "name": "Restless",
                "context": "adjective",
                "synonym": "",
                "phonetic": "RÉST-lâss",
                "creationDate": "2026-06-03T21:47:03.980Z",
                "meanings": [
                    {
                        "id": "2a46bacc-0729-4d8e-aaa0-a3b0e48f780c",
                        "definition": "Unwilling or unable to stay still or to be quiet and calm,  because you are worried or bored.",
                        "contexts": [
                            {
                                "id": "5f0f867c-9469-4502-a33b-bf831fb9ff6c",
                                "context": "literal"
                            }
                        ],
                        "examples": [
                            {
                                "id": "e336f0ed-c3dd-48ff-9d03-4d806d7fddda",
                                "text": "He’s a restless type - he never stays in one country for long.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "b862d1e3-7025-471b-8209-0d66b1df6d80",
                                "text": "She spend a restless night, tossing and turning.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "7df6bfbb-be30-4ee4-bae3-7dd3de99e15a",
                                "text": "He made eye contact with his wife and his restless movements diminished.",
                                "targetToBeHidden": ""
                            }
                        ],
                        "nextReviewDate": "2026-06-03T21:47:03.980Z",
                        "interval": 0,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    }
                ]
            },
            {
                "id": "1e762125-b342-482f-86d0-971dc4f948e4",
                "name": "Withdraw",
                "synonym": "",
                "phonetic": "with-DRÓN",
                "creationDate": "2026-05-31T01:32:37.261Z",
                "meanings": [
                    {
                        "id": "1353434c-1082-4886-943b-2e0a435e70b4",
                        "definition": "To take or move out or back, or to remove.",
                        "contexts": [
                            {
                                "id": "2ea66fd5-c1b7-4b2f-9027-db9a361679d4",
                                "context": "verb"
                            }
                        ],
                        "examples": [
                            {
                                "id": "964b88b9-a4a3-431f-a85e-7cc36dcd5c4f",
                                "text": "The UN has withdrawn its troops from the country.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "5a3bd8c3-2bdd-4848-bc72-91a343d4db51",
                                "text": "Eleven million bottles of water had to be withdrawn from sale due to a health scare.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "6cceeab1-ffbf-4adc-b0b6-26fcf9543e85",
                                "text": "After lunch, we withdrew into her office to finish our discussion in private.",
                                "targetToBeHidden": ""
                            }
                        ],
                        "nextReviewDate": "2026-05-31T01:32:37.261Z",
                        "interval": 0,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    },
                    {
                        "id": "906eace0-6a4a-4b29-9e81-fbd35e9e6ed8",
                        "definition": "Quiet, not outgoing, distant, not wanting to interact much; emotionally pulled back.",
                        "contexts": [
                            {
                                "id": "72bee2b6-4d23-476d-a8e8-b29060dfa44b",
                                "context": "adjective"
                            }
                        ],
                        "examples": [
                            {
                                "id": "73fb79b2-b654-4312-99ab-c42abd4acff6",
                                "text": "Since the accident, he has been very withdrawn.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "e62db51a-2488-4fa9-8306-c594e73edca4",
                                "text": "She was a shy, withdrawn child.",
                                "targetToBeHidden": ""
                            }
                        ],
                        "nextReviewDate": "2026-05-31T01:32:37.261Z",
                        "interval": 0,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    },
                    {
                        "id": "520e3349-32b2-43f1-bc4b-fb7a4a64bcb4",
                        "definition": "to stop talking to other people and start thinking thoughts that are not related to what is happening around you",
                        "contexts": [
                            {
                                "id": "1f2250ed-b8f6-4a29-afed-9b3be9237881",
                                "context": "verb"
                            }
                        ],
                        "examples": [
                            {
                                "id": "93f309ef-f1e3-426e-8799-304398879b46",
                                "text": "As a child, she frequently withdrew into her own fantasy world.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "1ab4e476-39e2-42d7-b0d8-17634ea06628",
                                "text": "After the accident, he withdrew into himself and refused to talk to family or friends.",
                                "targetToBeHidden": ""
                            }
                        ],
                        "nextReviewDate": "2026-05-31T01:32:37.261Z",
                        "interval": 0,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    }
                ]
            },
            {
                "id": "72447927-3783-451a-a9f9-dfd559d2ddd0",
                "name": "Deem",
                "context": "verb",
                "synonym": "",
                "phonetic": "diim",
                "creationDate": "2026-05-31T01:08:56.906Z",
