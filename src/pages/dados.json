            {
                "id": "91067c1d-ac2b-4284-b290-84074e6006e5",
                "name": "Witness ",
                "synonym": "",
                "phonetic": "UÍT-nâss",
                "creationDate": "2026-05-27T03:06:27.485Z",
                "meanings": [
                    {
                        "id": "e33983b2-18b3-4008-a683-f9a5d33894d2",
                        "definition": "A person who sees an event happening, specially a crime or an accident.",
                        "contexts": [
                            {
                                "id": "fae707b3-edd5-4864-995a-4c3b3b376465",
                                "context": "noun"
                            }
                        ],
                        "examples": [
                            {
                                "id": "c36aed5a-136e-4513-9d99-9dd85f92db4b",
                                "text": "According to witnesses, the car used in the robbery was a green van with Pennsylvania license plates.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "e5e286cb-2235-418d-871a-21924a833d61",
                                "text": "She was a witness at their wedding.",
                                "targetToBeHidden": ""
                            }
                        ],
                        "nextReviewDate": "2026-05-27T03:06:27.485Z",
                        "interval": 0,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    },
                    {
                        "id": "a7c5edf1-c8b7-4f70-b826-76a09425f115",
                        "definition": "to see something happen, especially something important/unusual.",
                        "contexts": [
                            {
                                "id": "f1c03c5d-ccfe-406f-8400-c2776e5aa227",
                                "context": "verb"
                            }
                        ],
                        "examples": [
                            {
                                "id": "dbc2c902-aedd-4610-b060-d378b3db11df",
                                "text": "I witnessed the car crash.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "b53262dc-2230-4e3b-baff-0e32236d641e",
                                "text": "He arrived home just in time to witness his brother being taken away by the police.",
                                "targetToBeHidden": ""
                            }
                        ],
                        "nextReviewDate": "2026-05-27T03:06:27.485Z",
                        "interval": 0,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    }
                ]
            },
            {
                "id": "41ceee73-b00a-4f0d-9e0a-85162c5839fe",
                "name": "Seek",
                "context": "verb",
                "synonym": "search",
                "phonetic": "s-III-k",
                "creationDate": "2026-05-27T03:02:29.428Z",
                "meanings": [
                    {
                        "id": "74a362d4-fb15-45ad-8267-ba48d1e770ab",
                        "definition": "To try to find or get something, specially something that is not a physical object.",
                        "contexts": [
                            {
                                "id": "18ca20df-7032-49f0-993c-62ed1f36b8a3",
                                "context": "formal"
                            }
                        ],
                        "examples": [
                            {
                                "id": "4ad6b7ec-0633-4c8f-9d2e-92f568261c33",
                                "text": "Are you actively seeking jobs",
                                "targetToBeHidden": "seeking"
                            },
                            {
                                "id": "790a4a57-f7b9-44cc-890a-adbca47497bb",
                                "text": "Hundreds of dissidents are seeking refuge in the U.S.",
                                "targetToBeHidden": "seeking"
                            },
                            {
                                "id": "298aefe0-f736-4e89-b19d-c1ac2e437c11",
                                "text": "The children sought their lost dog.",
                                "targetToBeHidden": "sought"
                            }
                        ],
                        "nextReviewDate": "2026-06-17T03:00:00.000Z",
                        "interval": 1,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    }
                ]
            },
            {
                "id": "e468d1af-a861-4481-9479-fcae4effc308",
                "name": "Intent ",
                "synonym": "",
                "phonetic": "in-TÉNT",
                "creationDate": "2026-05-27T00:35:04.700Z",
                "meanings": [
                    {
                        "id": "262b1c0e-15db-4dbf-be4e-a8061146fa44",
                        "definition": "Something that you intend or intended to do.",
                        "contexts": [
                            {
                                "id": "b65f72d1-6a82-4937-9da2-c26dc8b685c6",
                                "context": "noun"
                            }
                        ],
                        "examples": [
                            {
                                "id": "a94a0ef8-fc80-495f-ad79-cb17f9eca4ba",
                                "text": "There was clearly no intent to cause harm, and the judge ruled that the injury was accidental.",
                                "targetToBeHidden": "intent"
                            },
                            {
                                "id": "ba096d22-8a8b-4b46-a66a-8b2b303d813f",
                                "text": "He acted with criminal intent.",
                                "targetToBeHidden": "intent."
                            }
                        ],
                        "nextReviewDate": "2026-06-17T03:00:00.000Z",
                        "interval": 1,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    },
                    {
                        "id": "80fc1ab6-538f-46d0-b210-557789365bd1",
                        "definition": "Very focused on something; determined; absorbed; with strong attention or purpose.",
                        "contexts": [
                            {
                                "id": "dfe24963-2231-43bf-a4ca-4e1edf81aeb2",
                                "context": "adjective"
                            }
                        ],
                        "examples": [
                            {
                                "id": "49ea2df4-2e22-4bcf-8faf-c963185aa390",
                                "text": "She is intent on improving her English.",
                                "targetToBeHidden": "intent"
                            },
                            {
                                "id": "8dfa7419-122e-4fe9-9735-782299b33950",
                                "text": "The company is intent on expanding into new markets.",
                                "targetToBeHidden": "intent"
                            },
                            {
                                "id": "3e55c7e8-3702-4f84-9410-84df9c67f5c1",
                                "text": "He listened with intent attention.",
                                "targetToBeHidden": "intent"
                            },
                            {
                                "id": "ad49f052-cec9-4905-b241-4e51962837f5",
                                "text": "The child watched the magician with intent eyes.",
                                "targetToBeHidden": "intent"
                            }
                        ],
                        "nextReviewDate": "2026-06-20T03:00:00.000Z",
                        "interval": 4,
                        "repetitions": 2,
                        "easeFactor": 2.5
                    },
                    {
                        "id": "4dff0b28-55f0-48a0-9b67-0504ec2020bc",
                        "definition": "To have as a plan or purpose.",
                        "contexts": [
                            {
                                "id": "f071b16f-0680-455e-b51b-f92158df3f17",
                                "context": "verb"
                            }
                        ],
                        "examples": [
                            {
                                "id": "89e44954-713c-491f-a334-5aea23520f7b",
                                "text": "We intend to go to Australia next year.",
                                "targetToBeHidden": "intend"
                            },
                            {
                                "id": "7ec28e9c-7ca7-45c7-81fb-6f678dd9165e",
                                "text": "Somehow I offended him, which wasn't what I'd intended.",
                                "targetToBeHidden": "intended."
                            },
                            {
                                "id": "cc713f09-44c0-4394-92f9-7ea3a4b0214d",
                                "text": "I don't think she intended me to hear the remark.",
                                "targetToBeHidden": "intended"
