                        "definition": "To consider or judge something in a particular way.",
                        "contexts": [
                            {
                                "id": "7ca7b0bf-6eeb-4206-aa24-8c3837842b60",
                                "context": "formal"
                            }
                        ],
                        "examples": [
                            {
                                "id": "daa09ae0-a4ec-4df4-8112-270f897a6a49",
                                "text": "The area has now been deemed safe.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "d7f3bbf0-6c6d-49d3-8704-98aec254a920",
                                "text": "We will provide help whenever you deem it appropriate.",
                                "targetToBeHidden": ""
                            },
                            {
                                "id": "8fda107b-07a7-47fa-b174-5ab3ade47f7a",
                                "text": "Anyone not paying the registration fee by 31 March will be deemed to have withdrawn from the offer.",
                                "targetToBeHidden": ""
                            }
                        ],
                        "nextReviewDate": "2026-05-31T01:08:56.906Z",
                        "interval": 0,
                        "repetitions": 0,
                        "easeFactor": 2.5
                    }
                ]
            },
            {
